rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    match /media/users/{uid}/{allPaths=**} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    match /articles/{authorId}/{allPaths=**} {
      allow read, write: if isSignedIn() && request.auth.uid == authorId;
    }
  }
}
